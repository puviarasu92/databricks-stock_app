# GitHub Actions Environment Configuration

# Development Environment
DATABRICKS_HOST_DEV=dev-workspace.cloud.databricks.com
DATABRICKS_WORKSPACE_PATH_DEV=/Users/dev-deployer@company.com
DATABRICKS_CATALOG_DEV=dev_catalog

# Staging Environment
DATABRICKS_HOST_STAGING=staging-workspace.cloud.databricks.com
DATABRICKS_WORKSPACE_PATH_STAGING=/Users/staging-deployer@company.com
DATABRICKS_CATALOG_STAGING=staging_catalog

# Production Environment
DATABRICKS_HOST_PROD=prod-workspace.cloud.databricks.com
DATABRICKS_WORKSPACE_PATH_PROD=/Users/prod-deployer@company.com
DATABRICKS_CATALOG_PROD=prod_catalog

# General Configuration
DEPLOYMENT_APP_NAME=databricks-gold-table-viewer
DEPLOYMENT_TIMEOUT_SECONDS=300
DEPLOYMENT_RETRIES=3
